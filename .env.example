# ==================== BACKEND CONFIGURATION ====================

# Google Gemini API Key (Get from: https://aistudio.google.com/app/apikeys)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Email Configuration (Gmail SMTP or custom mail server)
# For Gmail: Use "App Password" if 2FA is enabled
# For custom server: Update SMTP_SERVER and SMTP_PORT accordingly
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_specific_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# API Security - Change this in production!
API_KEY_SECRET=your-secret-api-key-change-in-production

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ==================== FRONTEND CONFIGURATION ====================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== DOCKER & DEPLOYMENT ====================

# Python version (if using Docker)
PYTHON_VERSION=3.11

# Node version (if using Docker)
NODE_VERSION=18
